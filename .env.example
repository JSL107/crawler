# 서버 포트 (기본값 3000). 로컬에 이미 상주 중인 다른 프로젝트 서비스(3000, 3001) 와 충돌 회피 위해 3002 로 분리.
PORT=3002

# Redis 연결 정보 (BullMQ — crawler 도메인)
# 포트는 docker-compose 의 redis 호스트 포트(6381)와 매칭. 타 프로젝트 Redis(6379/6380) 와 충돌 회피 목적.
REDIS_HOST=localhost
REDIS_PORT=6381

# PostgreSQL 연결 (Prisma + docker-compose)
# docker-compose.yml 은 이 값들을 environment 에 interpolation — 하드코딩된 credential 을 저장소에 두지 않기 위함.
# 자격증명/포트를 바꾸려면 여기 4개 + docker-compose.yml 을 함께 갱신. (비밀번호를 강하게 바꾸려면 DATABASE_URL 도 같이.)
POSTGRES_USER=idaeri
POSTGRES_PASSWORD=idaeri
POSTGRES_DB=idaeri
DATABASE_URL=postgresql://idaeri:idaeri@localhost:5434/idaeri?schema=public

# Slack 봇 (이대리 — Socket Mode).
# 3개 모두 설정된 경우에만 Slack 봇이 기동됨. 하나라도 비어 있으면 앱은 정상 부팅하되 Slack 기능만 비활성화.
# 발급 경로: https://api.slack.com/apps (Socket Mode On → App-Level Token scope=connections:write)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
